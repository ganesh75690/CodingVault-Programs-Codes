class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
    }
}

public class MiddleNode {
    static Node head;

    static void insert(int data) {
        Node node = new Node(data);

        if (head == null)
            head = node;
        else {
            Node temp = head;

            while (temp.next != null)
                temp = temp.next;

            temp.next = node;
        }
    }

    static void middle() {
        Node slow = head;
        Node fast = head;

        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }

        System.out.println(slow.data);
    }

    public static void main(String[] args) {
        insert(10);
        insert(20);
        insert(30);
        insert(40);
        insert(50);

        middle();
    }
}
