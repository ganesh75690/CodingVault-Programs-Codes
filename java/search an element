class Node {
    int data;
    Node next;

    Node(int data) {
        this.data = data;
    }
}

public class SearchNode {
    static Node head;

    static void insert(int data) {
        Node node = new Node(data);

        if (head == null)
            head = node;
        else {
            Node temp = head;

            while (temp.next != null)
                temp = temp.next;

            temp.next = node;
        }
    }

    static boolean search(int key) {
        Node temp = head;

        while (temp != null) {
            if (temp.data == key)
                return true;

            temp = temp.next;
        }

        return false;
    }

    public static void main(String[] args) {
        insert(10);
        insert(20);
        insert(30);

        System.out.println(search(20));
    }
}
